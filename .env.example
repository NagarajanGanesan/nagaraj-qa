# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template — copy to .env and fill in real values.
# .env is git-ignored; this file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Gateway ───────────────────────────────────────────────────────────────
DEV_GATEWAY_URL=https://your-dev-hostname.example.com
QA_GATEWAY_URL=http://your-qa-server-ip

# ── PostgreSQL (credential source for api_key / client_id) ───────────────────
DEV_DB_HOST=your-dev-db-host
DEV_DB_PORT=4046
DEV_DB_USERNAME=xxx_app
DEV_DB_PASSWORD=

QA_DB_HOST=your-qa-db-host
QA_DB_PORT=4046
QA_DB_USERNAME=xxx_qa
QA_DB_PASSWORD=

# ── MongoDB ───────────────────────────────────────────────────────────────────
DEV_MONGODB_URI=mongodb://localhost:27017/
DEV_MONGODB_DB=xxx_db

# ── App / RBAC credentials (from Gateway setup — run TC01_OneTime_Setup once) ─
DEV_APP_CODE=your-app-code-uuid
DEV_API_KEY=your-api-key-hex-64chars
DEV_CLIENT_ID=your-client-id

# ── Test user credentials ─────────────────────────────────────────────────────
DEV_USERNAME=your-username
DEV_PASSWORD=your-password
